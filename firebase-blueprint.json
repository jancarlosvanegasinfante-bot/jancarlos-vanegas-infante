{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Un producto del catálogo con control de inventario.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "storeId": { "type": "string", "description": "ID del negocio al que pertenece" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "currency": { "type": "string" },
        "category": { "type": "string" },
        "cost": { "type": "number" },
        "freight": { "type": "number" },
        "provider": { "type": "string" }
      },
      "required": ["id", "storeId", "name", "price", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Un pedido realizado por un cliente vía WhatsApp.",
      "type": "object",
      "properties": {
        "storeId": { "type": "string", "description": "ID de la tienda" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "productName": { "type": "string" },
        "productId": { "type": "string" },
        "quantity": { "type": "number" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pendiente", "despachado", "entregado"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["storeId", "customerName", "customerPhone", "address", "city", "productId", "quantity"]
    },
    "Activity": {
      "title": "Activity",
      "description": "Log de actividad de WhatsApp en tiempo real.",
      "type": "object",
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "storeId": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["recibido", "procesando", "respondido", "error"] },
        "whatsappStatus": { "type": "string", "enum": ["sent", "delivered", "read", "failed"] },
        "statusUpdateAt": { "type": "string", "format": "date-time" },
        "response": { "type": "string" },
        "manualAgent": { "type": "string", "description": "Nombre del asesor que intervino" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["from", "storeId", "status", "timestamp"]
    },
    "Store": {
      "title": "Store",
      "description": "Configuración de una tienda en el SaaS.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "ID del negocio" },
        "ownerId": { "type": "string", "description": "Firebase Auth UID del dueño" },
        "slug": { "type": "string", "description": "URL amigable (ej: odontologia-feliz)" },
        "name": { "type": "string" },
        "description": { "type": "string", "description": "Qué hace la tienda" },
        "botName": { "type": "string", "description": "Nombre del bot (ej: Luis)" },
        "botTone": { "type": "string", "description": "Tono de la IA (ej: Empático y profesional)" },
        "botGoal": { "type": "string", "description": "Objetivo de la IA (ej: Agendar citas)" },
        "themeColor": { "type": "string", "description": "Color hexadecimal principal" },
        "phone": { "type": "string", "description": "Teléfono propio o dejar vacío si usa el global" },
        "notificationPhone": { "type": "string", "description": "Número de WhatsApp para recibir notificaciones de pedidos (ej: +57310...)" },
        "dropiApiKey": { "type": "string" },
        "emailEnabled": { "type": "boolean" },
        "recoveryFrequency": { "type": "number", "description": "Minutos de inactividad para marcar como abandono" },
        "btnNotificationLabel": { "type": "string", "description": "Texto del botón de notificación (ej: NOTIFICAR PRUEBA)" },
        "btnQuick1Label": { "type": "string", "description": "Atajo rápido 1 (ej: BENEFICIO)" },
        "btnQuick1Message": { "type": "string", "description": "Mensaje para el atajo rápido 1" },
        "btnQuick2Label": { "type": "string", "description": "Atajo rápido 2 (ej: CIERRE)" },
        "btnQuick2Message": { "type": "string", "description": "Mensaje para el atajo rápido 2" },
        "btnQuick3Label": { "type": "string", "description": "Atajo rápido 3 (ej: PRIORIDAD)" },
        "btnQuick3Message": { "type": "string", "description": "Mensaje para el atajo rápido 3" },
        "msgNewOrderTemplate": { "type": "string", "description": "Plantilla de mensaje para nuevos pedidos" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "slug"]
    },
    "TestConnection": {
      "title": "TestConnection",
      "description": "Documento para probar conectividad.",
      "type": "object",
      "properties": {
        "status": { "type": "string" }
      }
    },
    "SystemConfig": {
      "title": "SystemConfig",
      "description": "Estado global del sistema y alertas técnicas.",
      "type": "object",
      "properties": {
        "twilioLimitReached": { "type": "boolean" },
        "lastTwilioError": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Customer": {
      "title": "Customer",
      "description": "Perfil persistente de un cliente para memoria a largo plazo.",
      "type": "object",
      "properties": {
        "storeId": { "type": "string" },
        "name": { "type": "string" },
        "gender": { "type": "string", "enum": ["male", "female", "unknown"] },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "lastInteraction": { "type": "string", "format": "date-time" }
      },
      "required": ["storeId", "phone", "name"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "Estado de la conversación (ej: si la IA está pausada).",
      "type": "object",
      "properties": {
        "phone": { "type": "string" },
        "storeId": { "type": "string", "description": "Con qué tienda está hablando actualmente" },
        "aiPaused": { "type": "boolean" },
        "lastInterventionBy": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "FollowUp": {
      "title": "Follow Up",
      "description": "Seguimiento individual programado para reactivar ventas.",
      "type": "object",
      "properties": {
        "storeId": { "type": "string" },
        "phone": { "type": "string" },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "executed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "initialScore": { "type": "number" },
        "reason": { "type": "string" }
      },
      "required": ["storeId", "phone", "scheduledAt", "status", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Colección de productos con stock."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Colección de pedidos capturados por el bot."
    },
    "/activities/{activityId}": {
      "schema": "Activity",
      "description": "Log de eventos de entrada y salida de WhatsApp."
    },
    "/stores/{storeId}": {
      "schema": "Store",
      "description": "Configuraciones de tiendas en el SaaS."
    },
    "/test/{docId}": {
      "schema": "TestConnection",
      "description": "Prueba de conectividad."
    },
    "/config/{configId}": {
      "schema": "SystemConfig",
      "description": "Alertas y estados globales del sistema (ej. Límites Twilio)."
    },
    "/customers/{phone}": {
      "schema": "Customer",
      "description": "Base de datos de clientes recurrentes (Memoria de Jan)."
    },
    "/conversations/{phone}": {
      "schema": "Conversation",
      "description": "Estado operativo del chat (Pausa IA, etc)."
    },
    "/followups/{followupId}": {
      "schema": "FollowUp",
      "description": "Cronómetros individuales de reactivación de ventas."
    }
  }
}
