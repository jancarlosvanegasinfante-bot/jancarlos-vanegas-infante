rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'jancarlosvanegasinfante@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'price', 'stock']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.stock is number && data.stock >= 0;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['productId', 'customerPhone', 'quantity', 'address', 'city']) &&
             data.productId is string && data.productId.size() <= 128 &&
             data.customerPhone is string && data.customerPhone.size() <= 20 &&
             data.quantity is number && data.quantity > 0 &&
             data.address is string && data.address.size() <= 250 &&
             data.city is string && data.city.size() <= 100;
    }

    function isValidActivity(data) {
      return data.keys().hasAll(['from', 'to', 'storeId', 'status', 'timestamp']) &&
             data.from is string && data.from.size() <= 50 &&
             data.to is string && data.to.size() <= 50 &&
             data.storeId is string && data.storeId.size() <= 50 &&
             data.status in ['recibido', 'procesando', 'respondido', 'error'] &&
             data.timestamp == request.time;
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['phone', 'name']) &&
             data.phone is string && data.phone.size() <= 20 &&
             data.name is string && data.name.size() <= 100;
    }

    // --- Collections ---

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming()) && isValidId(productId);
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && existing().customerPhone == request.auth.token.phone_number);
      allow create: if isValidOrder(incoming()) && isValidId(orderId) &&
                   (isAdmin() || incoming().customerPhone == request.auth.token.phone_number);
      allow update: if isAdmin() || (
        isSignedIn() && existing().customerPhone == request.auth.token.phone_number &&
        incoming().diff(existing()).affectedKeys().hasOnly(['address', 'city'])
      );
      allow delete: if isAdmin();
    }

    match /activities/{activityId} {
      allow read: if isAdmin();
      allow create: if isValidActivity(incoming()) && isValidId(activityId);
      allow update: if isAdmin() || (
        isValidActivity(incoming()) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'whatsappStatus', 'statusUpdateAt', 'response', 'respondedAt'])
      );
      allow delete: if isAdmin();
    }

    match /stores/{storeId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /customers/{phone} {
      allow read: if isAdmin() || (isSignedIn() && phone == request.auth.uid);
      allow write: if isAdmin() || (isSignedIn() && phone == request.auth.uid && isValidCustomer(incoming()));
    }

    match /conversations/{phone} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /followups/{followupId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /test/{docId} {
      allow read, write: if true; // Used for connection testing
    }

    // Admins collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
